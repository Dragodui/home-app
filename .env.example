MODE=dev
# configs
DB_DSN=postgres://postgres:postgres@localhost:5432/db
PORT=8000
JWT_SECRET=JWT_SECRET
CLIENT_URL=http://localhost:8081
WEB_URL=http://localhost:8082
SERVER_URL=http://localhost:8000

# OAuth
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID
CLIENT_CALLBACK_URL=http://localhost:8000/auth/google/callback

# redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=REDIS_PASS
REDIS_TLS=true

# mailer (Brevo HTTP API - works on Render, no SMTP port blocking)
BREVO_API_KEY=your-brevo-api-key
SMTP_FROM=your-verified-sender@example.com

# S3 Configuration
R2_ACCESS_KEY_ID=r2_access_key
R2_SECRET_ACCESS_KEY=r2_secret_access_key
R2_S3_BUCKET=my-app

R2_ACCOUNT_ID=r2_account_id
R2_PUBLIC_URL=https://pub-<id>.r2.dev

# Home Assistant token encryption (exactly 32 characters for AES-256)
HA_ENCRYPTION_KEY=your-32-char-encryption-key-here!

# Gemini API (free tier: https://ai.google.dev/)
GEMINI_API_KEY=your-gemini-api-key

# basic auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin